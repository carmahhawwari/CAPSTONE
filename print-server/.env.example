# Supabase connection (use service_role key so the Pi bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# This printer's ID (from the printers table)
PRINTER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# USB printer vendor/product IDs (find with `lsusb`)
# Brightek POS80 defaults:
USB_VENDOR_ID=0x0483
USB_PRODUCT_ID=0x5743

# Poll interval in seconds
POLL_INTERVAL=3
